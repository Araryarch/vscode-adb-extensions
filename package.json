{
  "name": "vs-android-runner",
  "displayName": "VS Android Runner",
  "description": "Manage and run Android Emulators directly within VS Code without needing to open Android Studio.",
  "version": "0.1.0",
  "publisher": "vscode-adb-extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/Araryarch/vscode-adb-extensions.git"
  },
  "bugs": {
    "url": "https://github.com/Araryarch/vscode-adb-extensions/issues"
  },
  "homepage": "https://github.com/Araryarch/vscode-adb-extensions#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "android",
    "emulator",
    "avd",
    "adb",
    "android studio"
  ],
  "main": "./out/extension.js",
  "icon": "resources/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "vsAndroidRunner.refresh",
        "title": "Refresh AVD List",
        "icon": "$(refresh)"
      },
      {
        "command": "vsAndroidRunner.createAvd",
        "title": "Create New AVD",
        "icon": "$(add)"
      },
      {
        "command": "vsAndroidRunner.runAvd",
        "title": "Run Emulator",
        "icon": "$(play)"
      },
      {
        "command": "vsAndroidRunner.coldBootAvd",
        "title": "Run Cold Boot",
        "icon": "$(debug-restart)"
      },
      {
        "command": "vsAndroidRunner.stopAvd",
        "title": "Stop Emulator",
        "icon": "$(debug-stop)"
      },
      {
        "command": "vsAndroidRunner.showLogcat",
        "title": "Show Logcat",
        "icon": "$(output)"
      },
      {
        "command": "vsAndroidRunner.setSdkPath",
        "title": "Set Android SDK Path",
        "icon": "$(settings-gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vsAndroidRunner",
          "title": "Android Runner",
          "icon": "resources/android-logo.svg"
        }
      ]
    },
    "views": {
      "vsAndroidRunner": [
        {
          "id": "vsAndroidRunner.avdList",
          "name": "Android Virtual Devices",
          "contextualTitle": "Android Runner"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "vsAndroidRunner.refresh",
          "when": "view == vsAndroidRunner.avdList",
          "group": "navigation@1"
        },
        {
          "command": "vsAndroidRunner.createAvd",
          "when": "view == vsAndroidRunner.avdList",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "vsAndroidRunner.runAvd",
          "when": "view == vsAndroidRunner.avdList && viewItem == avd-stopped",
          "group": "inline@1"
        },
        {
          "command": "vsAndroidRunner.stopAvd",
          "when": "view == vsAndroidRunner.avdList && viewItem == avd-running",
          "group": "inline@1"
        },
        {
          "command": "vsAndroidRunner.runAvd",
          "when": "view == vsAndroidRunner.avdList && viewItem == avd-stopped",
          "group": "1_run@1"
        },
        {
          "command": "vsAndroidRunner.coldBootAvd",
          "when": "view == vsAndroidRunner.avdList && viewItem == avd-stopped",
          "group": "1_run@2"
        },
        {
          "command": "vsAndroidRunner.showLogcat",
          "when": "view == vsAndroidRunner.avdList && viewItem == avd-running",
          "group": "2_debug@1"
        },
        {
          "command": "vsAndroidRunner.stopAvd",
          "when": "view == vsAndroidRunner.avdList && viewItem == avd-running",
          "group": "2_debug@2"
        }
      ]
    },
    "configuration": {
      "title": "VS Android Runner",
      "properties": {
        "vsAndroidRunner.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Manual override for the Android SDK path. Leave empty to auto-detect from ANDROID_HOME or ANDROID_SDK_ROOT environment variables."
        },
        "vsAndroidRunner.autoRefreshInterval": {
          "type": "number",
          "default": 10,
          "description": "Auto-refresh interval in seconds for checking running emulator status. Set to 0 to disable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.22.0"
  }
}
